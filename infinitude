# quick and dirty thermostat register request
post '/api/samreq' => sub {
    my $c = shift;
    my $reg = $c->req->json->{register};
    my ($tab,$row) = $reg =~ m/([0-9a-fA-F]{2})\s*([0-9a-fA-F]{2})$/;
    my $frame = $carbus->samreq(hex($tab),hex($row));
    $c->log->debug("Making Virtual SAM request: register $reg table $tab and row $row\n".$frame->frame_hex);
    $c->render( json=>{ frame_hex=>$frame->frame_hex });
};

# Set system mode (heat/cool/auto/off)
post '/api/mode' => sub {
    my $c = shift;
    my $mode = $c->req->param('mode');
    unless ($mode && $mode =~ /^(heat|cool|auto|off)$/i) {
        return $c->render(json => { error => 'mode must be heat, cool, auto, or off' }, status => 400);
    }
    $inf->set_system_mode($mode);
    $c->render(json => { mode => $mode });
};


# Set zone hold timer via RS485 (minutes, 0 to cancel)
post '/api/hold' => sub {
    my $c = shift;
    my $zone = $c->req->param('zone') // 1;
    my $duration = $c->req->param('duration');
    unless (defined $duration && $duration =~ /^\d+$/) {
        return $c->render(json => { error => 'duration required (minutes, 0 to cancel)' }, status => 400);
    }
    if ($sam) {
        try { $sam->set_zone_hold($zone + 0, $duration + 0) }
        catch { warn "RS485 hold write failed: $_" };
    }
    $c->render(json => { zone => $zone, duration => $duration + 0 });
};

# Set backlight level via RS485
post '/api/backlight' => sub {
    my $c = shift;
    my $level = $c->req->param('level');
    unless (defined $level) {
        return $c->render(json => { error => 'level required (on/off/2-8)' }, status => 400);
    }
    if ($sam) {
        try { $sam->set_backlight($level) }
        catch { warn "RS485 backlight write failed: $_" };
    }
    $c->render(json => { backlight => $level });
};


# access simple system config variables by path
any '/api/*variable_path' => sub {
	my $c = shift;
	my $xml = XML::Simple::Minded->new($store->get('systems.xml'));
	my $search = $xml->system();
	foreach my $node (split('/',$c->stash('variable_path'))) {
		$search = ($node =~ /^\d+$/) ? $search->[$node]
		                             : $search->$node;
	}
	my $setting = { status=>'success' };

	try {
		if (ref($search)) {
			# path returns a structure. Can modify.
			my %sets = %{$c->req->params->to_hash()};
			my $set_changes = delete $sets{set_changes} || 0; #set change flag upon request
			foreach my $key (keys %sets) {
				$set_changes ||= ($search->$key ne $sets{$key}); # set change flag if value has changed
				$search->$key([$sets{$key}]);
			}
			$setting->{data} = { %{$search->TO_JSON()} };
			$store->set('systems.xml',  $xml.'');
			$store->set('systems.json', $xml->_as_json());
			if (('POST' eq $c->req->method) or ('PUT' eq $c->req->method) or $set_changes) {
				$store->set(changes => 'true');
			}
		} else {
			#path is a scalar. return only.
			$setting->{data} = $search;
		}
	} catch {
		$setting->{status} = 'fail';
	};


	$c->render(json=>$setting);
};


