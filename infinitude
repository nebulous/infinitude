$config->{mqtt_topic}    = $ENV{MQTT_TOPIC}    || $config->{mqtt_topic};

my $handle;
my $carbus;
my $sam;
my $inf;
my $init_attempt;
my @ws_clients;
my $busloop_id;
my $scantab = 0;
my $scanrow = 0;
my $scansec = 0;
my $lastframe = 0;
my @sam_poll_regs = (
    [0x01, 0x04], # Device info - clears thermostat's SAM comm fault flag
    [0x30, 0x03], # Thermostat register
    [0x30, 0x05], # Thermostat register
);
my $sam_poll_idx = 0;
my $sam_poll_sec = 0;
my $use_serial = ( (defined($config->{serial_tty})    and $config->{serial_tty})
                or (defined($config->{serial_socket}) and $config->{serial_socket}) );

sub serial_init {
    return unless $use_serial;
    return if $init_attempt and time<($init_attempt+7);
    $init_attempt = time;
    return unless $use_serial;
    if (defined($config->{serial_tty}) and -e $config->{serial_tty}) {
        require IO::Termios;
        warn "Using $config->{serial_tty} serial interface\n";
        $handle ||= IO::Termios->open($config->{serial_tty},"38400,8,n,1");
    } else {
        warn "Can't find serial device: $config->{serial_tty}. Serial monitoring disabled.\n" if $config->{serial_tty};
        delete $config->{serial_tty};
    }
    if (defined($config->{serial_socket}) and not $handle) {
        require IO::Socket::IP;
        my ($host,$port) = split(':',$config->{serial_socket});
        $host //= 'localhost';
        $port //= 'telnet';
        warn "Using $host port $port for serial interface\n";
        $handle ||= IO::Socket::IP->new( PeerHost=>$host, PeerPort=>$port);
    }
    $carbus = CarBus->new($handle) if $handle;
    if ($handle and $config->{emulate_sam}) {
        require CarBus::SAM;
        $sam = CarBus::SAM->new(bus => $carbus, emulated_src => 'SAM');
        $sam->initialize_defaults();
        $inf->{sam} = $sam if $inf;    # keep Infinitude module in sync after reconnect
        warn "SAM emulation enabled\n";
    }
    bus_loop_start() if $carbus;
}

sub bus_loop_start {
    return if $busloop_id;
    $busloop_id = Mojo::IOLoop->recurring(0.0625 => sub {
        serial_init() if (!$carbus or time>($lastframe+10));
        # Active SAM polling - emulate real SAM querying thermostat registers
        if ($sam and $carbus and time >= $sam_poll_sec + 3) {
            $sam_poll_sec = time;
            my $reg = $sam_poll_regs[$sam_poll_idx];
            my $poll_frame = $sam->read_thermostat($reg->[0], $reg->[1]);
            $sam_poll_idx = ($sam_poll_idx + 1) % scalar(@sam_poll_regs);
        }
        if (my $frame = $carbus->get_frame) {
            return if (!$frame or !$frame->struct->{cmd});
            if ($sam and my $reply = $sam->handle_frame($frame)) {
                $carbus->write($reply);
                my $rstruc = $reply->frame_hash;
                $rstruc->{timestamp} = time;
                $rstruc->{emulated} = 1;
                $_->send({json => $rstruc}) for @ws_clients;
            }
            my $fstruc = $frame->frame_hash;
            $fstruc->{timestamp} = $lastframe = time;
            if ($fstruc->{cmd} eq 'reply') {
                my $payf = $fstruc->{payload};
                if ($payf) {
                    if ($payf->{rows} and $ENV{SCAN_THERMOSTAT}) {
                        $scanrow = $payf->{rows}+1;
                    }
                    $fstruc->{field} = { $fstruc->{reg_name}||'unknown' => $payf };
                }
            }

            if ($ENV{SCAN_THERMOSTAT}) {
                if (time>=$scansec+($ENV{SCAN_THERMOSTAT})) {
                    $scansec = time;
                    if ($scanrow > 0) {
                        $scanrow--;
                    }
                    if ($scanrow == 0) {
                        $scantab+=1;
                        $scanrow=1;
                        $scantab=0x01 if $scantab>0x51;
                    }
                    app->log->debug(sprintf("scanning table %02x row %02x", $scantab, $scanrow));
                    $carbus->samreq($scantab, $scanrow);
                }
            }
            $_->send({json => $fstruc}) for @ws_clients;
        }
    });
    warn "Bus loop started: $busloop_id\n";
}

serial_init();

# MQTT Discovery integration
my $mqtt = Infinitude::MQTT->new(store => $store, config => $config);
$inf = Infinitude->new(store => $store, mqtt => $mqtt, sam => $sam);

# --- MQTT command wiring ---

if ($mqtt->enabled) {
    app->log->info("MQTT: Connecting to $config->{mqtt_broker}");

    $mqtt->subscribe_commands(
        on_set_mode => sub {
            my ($mode) = @_;
            $inf->set_system_mode($mode);
            app->log->debug("MQTT: Set system mode to $mode");
        },
        on_set_temperature => sub {
            my ($zone_id, $temp) = @_;
            my $sys_mode = 'auto';
            if (my $xml_str = $store->get('systems.xml')) {
                my $xml = XML::Simple::Minded->new($xml_str);
                $sys_mode = lc($xml->system->config->mode . '');
            }
            if ($sys_mode eq 'heat') {
                $inf->set_zone_setpoint($zone_id, $temp, undef);
            } elsif ($sys_mode eq 'cool') {
                $inf->set_zone_setpoint($zone_id, undef, $temp);
            } else {
                $inf->set_zone_setpoint($zone_id, $temp, $temp);
            }
            app->log->debug("MQTT: Set zone $zone_id temperature to $temp");
        },
        on_set_temp_low => sub {
            my ($zone_id, $temp) = @_;
            $inf->set_zone_setpoint($zone_id, $temp, undef);
            app->log->debug("MQTT: Set zone $zone_id heat setpoint to $temp");
        },
        on_set_temp_high => sub {
            my ($zone_id, $temp) = @_;
            $inf->set_zone_setpoint($zone_id, undef, $temp);
            app->log->debug("MQTT: Set zone $zone_id cool setpoint to $temp");
        },
        on_set_fan => sub {
            my ($zone_id, $fan) = @_;
            $inf->set_zone_fan($zone_id, $fan);
            app->log->debug("MQTT: Set zone $zone_id fan to $fan");
        },
        on_set_preset => sub {
            my ($zone_id, $preset) = @_;
            my ($hold, $activity, $until);
            if ($preset eq 'none' || $preset eq 'schedule') {
                ($hold, $activity, $until) = ('off', '', {});
            } elsif ($preset =~ /^(home|away|sleep|wake)$/) {
                ($hold, $activity, $until) = ('on', $preset, qtr_hr());
            } elsif ($preset eq 'hold') {
                ($hold, $activity, $until) = ('on', 'manual', 'forever');
            } elsif ($preset eq 'hold_until') {
                ($hold, $activity, $until) = ('on', 'manual', qtr_hr((localtime)[2] + 1));
            }
            $inf->set_zone_hold($zone_id, $hold, $activity, $until) if defined $hold;
            app->log->debug("MQTT: Set zone $zone_id preset to $preset");
        },
    );

    Mojo::IOLoop->timer(30 => sub {
        $mqtt->publish_discovery;
        app->log->info("MQTT: Discovery published");
    });

    Mojo::IOLoop->recurring(1 => sub {
        $mqtt->tick;
    });
}

app->secrets([$config->{app_secret}]);
